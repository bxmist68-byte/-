  <!-- JavaScript -->
  <script>
    // 页面导航功能
    document.addEventListener('DOMContentLoaded', function() {
      // 获取所有导航链接
      const navLinks = document.querySelectorAll('nav a');
      // 获取所有页面区域
      const pageSections = document.querySelectorAll('.page-section');
      
      // 页面加载时检查URL参数
      function checkUrlParams() {
        const urlParams = new URLSearchParams(window.location.search);
        const activeSection = urlParams.get('active');
        
        if (activeSection) {
          // 隐藏所有页面区域
          pageSections.forEach(section => {
            section.classList.remove('active');
          });
          
          // 移除所有导航链接的活动状态
          navLinks.forEach(navLink => {
            navLink.classList.remove('bg-primary', 'text-white');
            navLink.classList.add('bg-white', 'text-primary', 'border', 'border-primary');
          });
          
          // 显示目标页面区域
          const targetSection = document.getElementById(activeSection);
          if (targetSection) {
            targetSection.classList.add('active');
          }
          
          // 设置对应导航链接为活动状态
          const targetNavLink = document.querySelector(`nav a[href="#${activeSection}"]`);
          if (targetNavLink) {
            targetNavLink.classList.remove('bg-white', 'text-primary', 'border', 'border-primary');
            targetNavLink.classList.add('bg-primary', 'text-white');
          }
          
          // 页面跳转时回到顶部
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }
      
      // 初始检查URL参数
      checkUrlParams();
      
      // 为每个导航链接添加点击事件
      navLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          
          // 获取目标页面ID
          const targetId = this.getAttribute('href').substring(1);
          
          // 隐藏所有页面区域
          pageSections.forEach(section => {
            section.classList.remove('active');
          });
          
          // 移除所有导航链接的活动状态
          navLinks.forEach(navLink => {
            navLink.classList.remove('bg-primary', 'text-white');
            navLink.classList.add('bg-white', 'text-primary', 'border', 'border-primary');
          });
          
          // 显示目标页面区域
          const targetSection = document.getElementById(targetId);
          if (targetSection) {
            targetSection.classList.add('active');
          }
          
          // 设置当前导航链接为活动状态
          this.classList.remove('bg-white', 'text-primary', 'border', 'border-primary');
          this.classList.add('bg-primary', 'text-white');
          
          // 页面跳转时回到顶部
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
      
      // 轮播图功能
      const carousel = document.getElementById('carousel');
      if (carousel) {
        const items = carousel.querySelectorAll('.carousel-item');
        const indicators = carousel.querySelectorAll('.absolute.bottom-4 button');
        const prevBtn = carousel.querySelector('.absolute.left-4');
        const nextBtn = carousel.querySelector('.absolute.right-4');
        let currentIndex = 0;
        
        function showSlide(index) {
          items.forEach(item => item.classList.remove('active'));
          indicators.forEach(indicator => {
            indicator.classList.remove('bg-white');
            indicator.classList.add('bg-white/50');
          });
          
          items[index].classList.add('active');
          indicators[index].classList.add('bg-white');
          indicators[index].classList.remove('bg-white/50');
        }
        
        function nextSlide() {
          currentIndex = (currentIndex + 1) % items.length;
          showSlide(currentIndex);
        }
        
        function prevSlide() {
          currentIndex = (currentIndex - 1 + items.length) % items.length;
          showSlide(currentIndex);
        }
        
        // 自动轮播
        let slideInterval = setInterval(nextSlide, 5000);
        
        // 事件监听
        if (nextBtn) {
          nextBtn.addEventListener('click', () => {
            clearInterval(slideInterval);
            nextSlide();
            slideInterval = setInterval(nextSlide, 5000);
          });
        }
        
        if (prevBtn) {
          prevBtn.addEventListener('click', () => {
            clearInterval(slideInterval);
            prevSlide();
            slideInterval = setInterval(nextSlide, 5000);
          });
        }
        
        // 动物档案更多按钮功能
        const loadMoreBtn = document.getElementById('load-more-pets');
        const petCardsContainer = document.getElementById('pet-cards');
        
        // 更多动物数据
        const morePets = [
          { id: 9, name: '来福', type: '柴犬', age: '2岁', image: 'https://picsum.photos/id/1077/200/200' },
          { id: 10, name: '阿黄', type: '中华田园犬', age: '3岁', image: 'https://picsum.photos/id/1075/200/200' },
          { id: 11, name: '雪球', type: '萨摩耶', age: '1.5岁', image: 'https://picsum.photos/id/237/200/200' },
          { id: 12, name: '警长', type: '英短蓝猫', age: '2.5岁', image: 'https://picsum.photos/id/1074/200/200' },
          { id: 13, name: '布丁', type: '布偶猫', age: '1岁', image: 'https://picsum.photos/id/206/200/200' },
          { id: 14, name: '土豆', type: '加菲猫', age: '3岁', image: 'https://picsum.photos/id/40/200/200' },
          { id: 15, name: '可乐', type: '哈士奇', age: '2岁', image: 'https://picsum.photos/id/1062/200/200' },
          { id: 16, name: '奶茶', type: '金毛', age: '3.5岁', image: 'https://picsum.photos/id/1071/200/200' }
        ];
        
        let petsLoaded = 8; // 初始加载的宠物数量
        
        if (loadMoreBtn && petCardsContainer) {
          loadMoreBtn.addEventListener('click', function() {
            // 每次加载4个宠物
            const newPetsToLoad = morePets.slice(petsLoaded - 8, petsLoaded - 8 + 4);
            
            // 创建新的宠物卡片
            newPetsToLoad.forEach(pet => {
              const petCard = document.createElement('div');
              petCard.className = 'pet-card p-6 text-center';
              petCard.innerHTML = `
                <div class="mb-4">
                  <img src="${pet.image}" alt="${pet.name}" class="pet-card-image">
                </div>
                <h3 class="text-xl font-bold mb-2">${pet.name}</h3>
                <p class="text-gray-600 mb-4">${pet.type} / ${pet.age}</p>
                <div class="flex justify-center space-x-2">
                  <a href="#" class="inline-block px-4 py-2 rounded-full bg-primary text-white font-medium btn-hover">
                    了解更多
                  </a>
                </div>
              `;
              petCardsContainer.appendChild(petCard);
            });
            
            petsLoaded += 4;
            
            // 如果没有更多宠物可加载，隐藏按钮
            if (petsLoaded >= 8 + morePets.length) {
              loadMoreBtn.style.display = 'none';
            }
          });
        }
        
        indicators.forEach((indicator, index) => {
          indicator.addEventListener('click', () => {
            clearInterval(slideInterval);
            currentIndex = index;
            showSlide(currentIndex);
            slideInterval = setInterval(nextSlide, 5000);
          });
        });
      }
      
      // 密码显示/隐藏功能
      const passwordInput = document.getElementById('password');
      // 密码显示/隐藏切换功能
      function togglePassword() {
        const passwordInput = document.getElementById('password');
        const eyeIcon = document.getElementById('password-eye');
        
        if (passwordInput && eyeIcon) {
          if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            eyeIcon.classList.remove('fa-eye');
            eyeIcon.classList.add('fa-eye-slash');
          } else {
            passwordInput.type = 'password';
            eyeIcon.classList.remove('fa-eye-slash');
            eyeIcon.classList.add('fa-eye');
          }
        }
      }
      
      // 登录表单提交功能
      const loginForm = document.getElementById('user-login-form');
      const loginFormContainer = document.getElementById('login-form');
      const userDashboard = document.getElementById('user-dashboard');
      const logoutBtn = document.getElementById('logout-btn');
      
      if (loginForm) {
        loginForm.addEventListener('submit', function(e) {
          e.preventDefault();
          
          // 获取用户名和密码
          const username = document.getElementById('username').value;
          const password = document.getElementById('password').value;
          
          // 简单的表单验证
          if (!username || !password) {
            alert('请输入用户名和密码！');
            return;
          }
          
          // 模拟登录成功
          alert('登录成功！欢迎回来，' + username + '！');
          
          // 隐藏登录表单，显示用户中心主页
          if (loginFormContainer && userDashboard) {
            loginFormContainer.classList.add('hidden');
            userDashboard.classList.remove('hidden');
          }
          
          // 清空表单
          loginForm.reset();
          
          // 将密码输入框改回密码类型
          const passwordInput = document.getElementById('password');
          if (passwordInput) {
            passwordInput.type = 'password';
          }
        });
      }
      
      // 登出功能
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          // 确认登出
          if (confirm('确定要退出登录吗？')) {
            // 隐藏用户中心主页，显示登录表单
            if (loginFormContainer && userDashboard) {
              userDashboard.classList.add('hidden');
              loginFormContainer.classList.remove('hidden');
            }
          }
        });
      }
      
      // 新成员投稿表单处理
      const newPetForm = document.getElementById('new-pet-form');
      if (newPetForm) {
        newPetForm.addEventListener('submit', function(e) {
          e.preventDefault();
          
          // 获取表单数据
          const petName = document.getElementById('pet-name').value;
          const petType = document.getElementById('pet-type').value;
          const petDescription = document.getElementById('pet-description').value;
          const petImage = document.getElementById('pet-image').files[0];
          
          // 简单的表单验证
          if (!petName || !petType || !petDescription || !petImage) {
            alert('请填写所有必填项并上传照片');
            return;
          }
          
          // 检查文件大小（最大5MB）
          if (petImage.size > 5 * 1024 * 1024) {
            alert('照片大小不能超过5MB');
            return;
          }
          
          // 模拟表单提交成功
          alert(`感谢您的投稿！\\n\\n动物名称：${petName}\\n动物种类：${petType === 'cat' ? '猫' : petType === 'dog' ? '狗' : petType === 'bird' ? '鸟' : '其他'}\\n\\n您的投稿已提交，我们将尽快审核。如果该动物在校园持续出没一个月以上，将会被正式归档为校园萌宠档案的常驻成员。`);
          
          // 重置表单
          newPetForm.reset();
        });
      }
    });
  </script>
</body>
</html>